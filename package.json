{
  "name": "ewegen-bff",
  "version": "1.0.0",
  "description": "eWegen Backend For Frontend component",
  "main": "src/ewegen-bff-service.ts",
  "scripts": {
    "start": "ts-node ./src/ewegen-bff-service",
    "debug": "DEBUG=ewegen-bff:* npm start",
    "dev": "nodemon -w ./src",
    "serve": "node dist/ewegen-bff-service.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "commit": "cz",
    "build": "tsc",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "security:check": "npm audit && npm outdated"
  },
  "keywords": [],
  "author": "Erol Zavidic",
  "license": "MIT",
  "type": "commonjs",
  "overrides": {
    "form-data": "^4.0.4"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.893.0",
    "@types/morgan": "^1.9.10",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "rotating-file-stream": "^3.2.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cookie-parser": "~1.4.8",
    "@types/debug": "~4.1.12",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.3",
    "@types/supertest": "^6.0.3",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.0.1",
    "debug": "~4.4.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
